# ============================================================
# DevOps Metrics Dashboard — ortam değişkenleri
# Bu dosyayı .env.local olarak kopyalayıp değerleri doldurun.
# ============================================================

# Veri kaynağı seçimi.
#   mock    -> connector'lar mock JSON döner (kimlik bilgisi gerekmez)
#   live    -> gerçek Jira / Jenkins REST API'leri doğrudan kullanılır
#   devlake -> HİBRİT: Apache DevLake'in DB'sinden okunur (önerilen)
DATA_SOURCE=mock

# Geriye dönük uyumluluk: DATA_SOURCE boşsa bu kullanılır.
# true -> mock, false -> live
USE_MOCK=true

# ------------------ DevLake (HİBRİT mod) --------------------
# DATA_SOURCE=devlake iken kullanılır. DevLake; Jira/Jenkins/GitHub'tan
# veriyi toplayıp DORA metriklerini kendi DB'sinde saklar, biz de bu DB'yi
# okuruz. DevLake varsayılanı MySQL'dir; PostgreSQL de desteklenir.
#   MySQL    : mysql://user:pass@host:3306/lake
#   Postgres : postgres://user:pass@host:5432/lake
DEVLAKE_DB_URL=mysql://merico:merico@devlake-mysql:3306/lake
# 'ALL' filtresi seçildiğinde sorgulanacak DevLake project_name listesi
DEVLAKE_PROJECTS=PAY,WEB,CORE

# ------------------------- Jira -----------------------------
# Lead Time ve MTTR (Incident) metrikleri için.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=devops@your-org.com
JIRA_TOKEN=your-jira-api-token
# Varsayılan olarak izlenecek proje key'leri (virgülle ayrılmış)
JIRA_PROJECT_KEYS=PAY,WEB,CORE
# Incident (arıza) issue'larını tespit etmek için issue type adı
JIRA_INCIDENT_ISSUE_TYPE=Incident

# ------------------------ Jenkins ---------------------------
# Deployment Frequency, Change Failure Rate ve Lead Time için.
JENKINS_URL=https://jenkins.your-org.com
JENKINS_USER=devops
JENKINS_TOKEN=your-jenkins-api-token
# Deployment job -> component eşlemesi (JSON).
# Örn: [{"job":"pay-deploy-prod","component":"PAY"},{"job":"web-deploy-prod","component":"WEB"}]
JENKINS_DEPLOY_JOBS=[{"job":"pay-deploy-prod","component":"PAY"},{"job":"web-deploy-prod","component":"WEB"},{"job":"core-deploy-prod","component":"CORE"}]

# --------------------- Metrics SQL DB -----------------------
# Bazı metrikler (ör. code coverage, test otomasyon oranı) metrics DB'den
# SQL query ile çekilir. PostgreSQL bağlantı stringi.
METRICS_DB_URL=postgres://user:password@db-host:5432/metrics

# ----------------- Grafana / Prometheus (opsiyonel) ---------
# Application Anomaly ve monitoring tabanlı Change Failure sinyalleri için.
GRAFANA_URL=https://grafana.your-org.com
GRAFANA_TOKEN=your-grafana-token
